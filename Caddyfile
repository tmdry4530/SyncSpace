# Caddyfile — SyncSpace web service (static SPA + reverse proxy to api).
#
# 역할 / role:
#   - 정적 빌드(/usr/share/caddy)를 SPA로 서빙 (try_files → /index.html).
#   - 백엔드 경로(/api, /a2a, /.well-known/agent-card.json, /skill.md, /skill.json, /chat, /doc,
#     /health, /ready)는 api 서비스(API_INTERNAL_URL)로 reverse_proxy.
#   - WebSocket(/chat/*, /doc/*) 업그레이드는 Caddy reverse_proxy가 기본 지원.
#
# env:
#   - PORT             : listen 포트 (Railway 주입)
#   - API_INTERNAL_URL : api private URL, 예) http://api.railway.internal:8080

{
	# 관리 API 비활성화 (불필요한 표면 제거)
	admin off
}

:{$PORT} {
	# 응답 압축
	encode gzip

	# --- 백엔드로 프록시되는 경로들 (REST / A2A / realtime / health) ---
	# 정적 핸들러보다 먼저 매칭되도록 명시한다.
	@backend {
		path /api/* /a2a/* /.well-known/agent-card.json /skill.md /skill.json /chat/* /doc/* /health /ready
	}
	# Caddy reverse_proxy는 Connection: Upgrade 헤더를 자동 처리하므로
	# /chat/*, /doc/* WebSocket 업그레이드가 그대로 통과한다.
	reverse_proxy @backend {$API_INTERNAL_URL}

	# --- 그 외 모든 요청: 정적 SPA ---
	root * /usr/share/caddy
	try_files {path} /index.html
	file_server
}
