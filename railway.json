{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm build",
    "watchPatterns": ["src/**","server/src/**","server/migrations/**","package.json","pnpm-lock.yaml","vite.config.ts","tsconfig.json","server/package.json","server/tsconfig.build.json"]
  },
  "deploy": {
    "preDeployCommand": "sh -c 'if [ -n \"${DATABASE_URL}${POSTGRES_URL}\" ]; then node server/dist/db/migrate.js; else echo \"DATABASE_URL not configured; skipping migrations\"; fi'",
    "startCommand": "pnpm --filter server start",
    "healthcheckPath": "/ready",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
