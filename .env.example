# SyncSpace backend environment
NODE_ENV=development
HOST=0.0.0.0
PORT=1234

# Structured log level: error|warn|info|debug
LOG_LEVEL=info

# Comma-separated browser origins allowed to open WebSocket connections.
# Use explicit origins in production. Use * only for local smoke tests.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Realtime authorization mode:
# - off: local/dev only; origin checks still apply
# - supabase: (legacy) require a Supabase access token + workspace membership for WS upgrades
# - session: app-owned session cookie auth (Railway target); validates auth_sessions + membership
WS_AUTH_MODE=off

# ============================================================================
# App-owned auth + Postgres (Railway)
# 이 섹션은 Supabase Auth/DB를 대체하는 자체 소유 인증 + Postgres 설정이다.
# api와 agent-worker 서비스에 동일하게 주입한다.
# ============================================================================

# Railway PostgreSQL 연결 문자열 (단일 영속 저장소). secret.
DATABASE_URL=postgres://user:password@host:5432/syncspace

# 세션/에이전트 토큰 서명용 비밀키. 충분히 긴 랜덤 값. secret.
AUTH_SECRET=replace-with-long-random-secret

# 세션 쿠키 이름 (기본 syncspace_session)
SESSION_COOKIE_NAME=syncspace_session

# 세션 쿠키 도메인 (예: .syncspace.app). 로컬은 비워둔다.
SESSION_COOKIE_DOMAIN=

# 에이전트 토큰 해시에 섞는 pepper. secret.
AGENT_TOKEN_PEPPER=replace-with-agent-token-pepper

# 외부에 노출되는 앱 기본 URL (쿠키/리다이렉트/A2A 카드 기준)
PUBLIC_APP_URL=https://syncspace.app

# A2A 프로토콜 버전 (고정)
A2A_VERSION=1.0

# A2A JSON-RPC interface (message:send / message:stream / tasks/{id}) 엔드포인트
A2A_INTERFACE_URL=https://syncspace.app/a2a

# A2A agent card URL (.well-known)
A2A_AGENT_CARD_URL=https://syncspace.app/.well-known/agent-card.json

# 문서(Yjs) 영속화 모드: file | postgres
# Railway 타깃은 postgres(yjs_document_snapshots). file은 로컬/폴백.
SYNCSPACE_DOC_PERSISTENCE_MODE=postgres

# Optional file-backed Yjs document snapshots (mode=file일 때 사용).
# Use a persistent volume in production.
SYNCSPACE_DOC_PERSISTENCE_DIR=.syncspace-data/ydocs

# ---- agent-worker 서비스 전용 ----------------------------------------------
# 워커 인스턴스 식별자 (멀티 워커 시 고유)
WORKER_ID=worker-1
# 에이전트 task 처리 워커 on/off
AGENT_WORKER_ENABLED=true
# push(웹훅) 전송 워커 on/off
PUSH_WORKER_ENABLED=true

# ============================================================================
# Supabase (legacy / removed after cutover)
# 컷오버(Phase 19-20) 완료 후 제거 대상. 마이그레이션 기간에만 유지한다.
# Never expose SUPABASE_SERVICE_ROLE_KEY to frontend code.
# ============================================================================
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-service-role-key

# Optional public frontend values belong in frontend-specific env files, not here:
# VITE_API_URL=/api
# VITE_WS_URL=wss://syncspace.app
# (legacy / removed after cutover)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# Frontend realtime auth hint. If omitted, the client auto-enables Supabase WS auth
# when VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY are present.
# Set off only for unauthenticated local smoke tests.
# VITE_WS_AUTH_MODE=off
