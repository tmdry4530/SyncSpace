# syntax=docker/dockerfile:1
#
# Dockerfile.web — SyncSpace web (frontend) service for Railway.
#
# 빌드 전략 / build strategy:
#   - 빌드 스테이지에서 FULL 모노레포를 빌드한다. 루트 `pnpm build`는
#     `tsc -p tsconfig.json && vite build && pnpm -r build` 이므로 프런트엔드
#     dist(/app/dist)가 생성된다. (server build도 함께 돌지만 산출물은 버림.)
#   - 최종 스테이지는 Caddy로 정적 SPA를 서빙하고 /api,/a2a,/chat,/doc,/health,/ready
#     등을 api 서비스(API_INTERNAL_URL)로 reverse_proxy 한다.
#
# 필요한 런타임 env / required runtime env (Railway web service):
#   - PORT               : Caddy listen 포트 (Railway가 주입)
#   - API_INTERNAL_URL   : api 서비스 private URL, 예) http://api.railway.internal:8080

# ---- build stage ------------------------------------------------------------
FROM node:22-alpine AS build
WORKDIR /app

# corepack로 lockfile에 고정된 pnpm 버전(pnpm@10.28.0) 활성화
RUN corepack enable

# 의존성 캐시 레이어: lockfile/매니페스트 먼저 복사
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY server/package.json ./server/package.json

RUN pnpm install --frozen-lockfile

# 소스 전체 복사 후 풀 빌드 (프런트엔드 dist 산출)
COPY . .
RUN pnpm build

# ---- runtime stage (Caddy static + reverse proxy) ---------------------------
FROM caddy:2-alpine AS runtime

# 빌드된 SPA 정적 산출물
COPY --from=build /app/dist /usr/share/caddy

# 리버스 프록시 + SPA fallback 설정
COPY Caddyfile /etc/caddy/Caddyfile

# Caddy는 Caddyfile의 {$PORT}를 사용해 listen 한다. (Railway가 PORT 주입)
EXPOSE 8080
CMD ["caddy", "run", "--config", "/etc/caddy/Caddyfile", "--adapter", "caddyfile"]
